---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getPublishedChapters } from '../lib/chapters';
import site from '../../content-meta/site.json';
import synopsis from '../../content-meta/synopsis.md?raw';

const chapters = await getPublishedChapters();
const totalWords = chapters.reduce((sum, c) => sum + c.data.wordCount, 0);
const progress = Math.round((chapters.length / site.targetChapters) * 100);
---

<BaseLayout title="书籍介绍" description={site.hook} path="/book">
  <div class="mx-auto max-w-2xl px-4 py-10">
    <h1 class="mb-2 font-serif text-3xl font-bold">{site.title}</h1>
    <p class="mb-8 text-ink/60">{site.subtitle}</p>

    <section class="mb-10 rounded-2xl border border-accent-light bg-white/50 p-6">
      <h2 class="mb-3 font-serif text-lg font-bold">连载进度</h2>
      <div class="mb-2 h-3 overflow-hidden rounded-full bg-accent-light">
        <div class="h-full rounded-full bg-accent transition-all" style={`width: ${progress}%`} />
      </div>
      <p class="text-sm text-ink/70">
        已更新 <strong>{chapters.length}</strong> / {site.targetChapters} 章 · 共{' '}
        <strong>{totalWords.toLocaleString()}</strong> 字
      </p>
    </section>

    <section class="prose prose-stone mb-10 max-w-none font-serif leading-relaxed">
      <h2 class="font-serif text-lg font-bold">简介</h2>
      <div class="whitespace-pre-line text-ink/80">{synopsis.replace(/^# .+\n\n/, '')}</div>
    </section>

    <section class="mb-10">
      <div class="mb-4 flex items-baseline justify-between gap-4">
        <h2 class="font-serif text-lg font-bold">核心角色</h2>
        <a href="/characters" class="shrink-0 text-sm text-accent hover:underline">角色一览 →</a>
      </div>
      <div class="grid gap-4 sm:grid-cols-3">
        <div class="rounded-xl border border-accent-light p-4">
          <p class="mb-1 text-2xl">🎒</p>
          <p class="font-bold">林小满</p>
          <p class="mt-1 text-sm text-ink/60">14 岁初二 · 黑板清单发起人 · 靠脑子活下去</p>
        </div>
        <div class="rounded-xl border border-accent-light p-4">
          <p class="mb-1 text-2xl">🌿</p>
          <p class="font-bold">苏晚晴</p>
          <p class="mt-1 text-sm text-ink/60">班长兼生物课代表 · 自带安全水源 · 清单第 101 条</p>
        </div>
        <div class="rounded-xl border border-accent-light p-4">
          <p class="mb-1 text-2xl">🪖</p>
          <p class="font-bold">老周</p>
          <p class="mt-1 text-sm text-ink/60">退伍军人 · 学校邻居 · 团队早期武力支柱</p>
        </div>
      </div>
    </section>

    <a
      href="/read/chapter-01"
      class="inline-flex min-h-12 items-center justify-center rounded-xl bg-accent px-8 text-white hover:bg-accent/90"
    >
      开始阅读第一章
    </a>
  </div>
</BaseLayout>