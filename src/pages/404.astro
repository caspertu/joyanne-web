---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="页面走丢了">
  <div class="mx-auto flex min-h-[70vh] max-w-md flex-col items-center justify-center px-4 text-center">
    <p class="mb-2 text-6xl">🌙</p>
    <h1 class="mb-4 font-serif text-2xl font-bold">这页好像走丢了</h1>
    <p class="mb-8 text-ink/60">七公主去别处发疯啦，咱们回目录找找？</p>
    <a
      href="/read"
      class="inline-flex min-h-12 items-center justify-center rounded-xl bg-accent px-8 text-white hover:bg-accent/90"
    >
      返回章节目录
    </a>
  </div>
</BaseLayout>