---
import BaseLayout from './BaseLayout.astro';
import '../styles/reader.css';
import ChapterNav from '../components/ChapterNav.astro';
import ReaderControls from '../components/ReaderControls.astro';

interface Props {
  title: string;
  chapterLabel: string;
  updatedLabel: string;
  slug: string;
  prevSlug: string | null;
  nextSlug: string | null;
  description?: string;
  ogType?: 'website' | 'article';
}

const { title, chapterLabel, updatedLabel, slug, prevSlug, nextSlug, description, ogType = 'article' } =
  Astro.props;
---

<BaseLayout title={title} description={description} path={`/read/${slug}`} showNav={false} ogType={ogType}>
  <div class="flex min-h-screen flex-col bg-paper">
    <header class="sticky top-0 z-10 border-b border-accent-light/60 bg-paper/95 backdrop-blur-sm">
      <div class="mx-auto flex max-w-3xl items-center justify-between px-4 py-3">
        <a href="/read" class="text-sm text-accent hover:underline" aria-label="返回目录">
          ← 目录
        </a>
        <ReaderControls slug={slug} />
      </div>
    </header>

    <main class="mx-auto w-full max-w-3xl flex-1 px-4 py-6 md:py-10">
      <article>
        <header class="mb-8 text-center">
          <p class="mb-2 text-sm tracking-widest text-accent/80">七公主的发疯日常</p>
          <h1 class="font-serif text-xl font-bold leading-snug md:text-2xl">{chapterLabel}</h1>
          <p class="mt-2 text-xs tracking-wide text-accent/60">{updatedLabel}</p>
        </header>
        <div class="reader-body" id="reader-content" data-slug={slug}>
          <slot />
        </div>
      </article>
    </main>

    <ChapterNav prevSlug={prevSlug} nextSlug={nextSlug} currentSlug={slug} />
  </div>
</BaseLayout>