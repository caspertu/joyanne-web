<!-- ══════════════════ Hero ══════════════════ -->
<main>
<section class="hero" data-od-id="hero" data-component="hero">
  <div class="hero-bg"></div>
  <div class="hero-flowers" id="heroFlowers"></div>
  <div class="hero-content fade-up">
    <h1>角色<span>图鉴</span></h1>
    <p class="hero-sub">听竹轩人力资源部 · 全员花名册</p>
    <div class="hero-line"></div>
  </div>
</section>

<!-- ══════════════════ Protagonist Faction ══════════════════ -->
<section class="section" id="protagonists" data-od-id="protagonists" data-component="protagonist-faction">
  <div class="section-header fade-up">
    <p class="section-sub">主角阵营</p>
    <h2>听竹轩招聘部</h2>
    <div class="section-line" style="background: var(--seed-primary);"></div>
  </div>

  <div class="card-grid">
    <!-- Card 1: Lin Wan'er -->
    <div class="char-card" style="--card-accent: #FFD700;" data-delay="0">
      <div class="card-avatar" style="background: linear-gradient(135deg, rgba(255,215,0,0.2), rgba(255,165,0,0.1));">
        <span class="card-avatar-letter">婉</span>
      </div>
      <div class="card-name">林婉儿 / 七公主宁璃</div>
      <div class="card-title">HR部门CEO</div>
      <p class="card-desc">35岁现代打工人灵魂，12岁公主身体。招牌动作：拍桌子、搓下巴、翻白眼。</p>
      <div class="card-flowers">
        <span class="card-flower"><svg viewBox="0 0 24 24"><circle class="petal" cx="12" cy="7" r="4"/><circle class="petal" cx="7" cy="12" r="4"/><circle class="petal" cx="17" cy="12" r="4"/><circle class="petal" cx="9" cy="17" r="4"/><circle class="petal" cx="15" cy="17" r="4"/><circle cx="12" cy="12" r="3" fill="#FFD700"/></svg></span>
        <span class="card-flower"><svg viewBox="0 0 24 24"><circle class="petal" cx="12" cy="7" r="4"/><circle class="petal" cx="7" cy="12" r="4"/><circle class="petal" cx="17" cy="12" r="4"/><circle class="petal" cx="9" cy="17" r="4"/><circle class="petal" cx="15" cy="17" r="4"/><circle cx="12" cy="12" r="3" fill="#FFD700"/></svg></span>
        <span class="card-flower"><svg viewBox="0 0 24 24"><circle class="petal" cx="12" cy="7" r="4"/><circle class="petal" cx="7" cy="12" r="4"/><circle class="petal" cx="17" cy="12" r="4"/><circle class="petal" cx="9" cy="17" r="4"/><circle class="petal" cx="15" cy="17" r="4"/><circle cx="12" cy="12" r="3" fill="#FFD700"/></svg></span>
        <span class="card-flower"><svg viewBox="0 0 24 24"><circle class="petal" cx="12" cy="7" r="4"/><circle class="petal" cx="7" cy="12" r="4"/><circle class="petal" cx="17" cy="12" r="4"/><circle class="petal" cx="9" cy="17" r="4"/><circle class="petal" cx="15" cy="17" r="4"/><circle cx="12" cy="12" r="3" fill="#FFD700"/></svg></span>
        <span class="card-flower"><svg viewBox="0 0 24 24"><circle class="petal" cx="12" cy="7" r="4"/><circle class="petal" cx="7" cy="12" r="4"/><circle class="petal" cx="17" cy="12" r="4"/><circle class="petal" cx="9" cy="17" r="4"/><circle class="petal" cx="15" cy="17" r="4"/><circle cx="12" cy="12" r="3" fill="#FFD700"/></svg></span>
      </div>
      <div class="card-quote">
        <div class="quote-bubble">"本宫不发疯，谁发疯？"</div>
      </div>
    </div>

    <!-- Card 2: Ning An -->
    <div class="char-card" style="--card-accent: #00D4FF;" data-delay="80">
      <div class="card-avatar" style="background: linear-gradient(135deg, rgba(0,212,255,0.2), rgba(0,150,200,0.1));">
        <span class="card-avatar-letter">安</span>
      </div>
      <div class="card-name">三公主宁安</div>
      <div class="card-title" style="color: #00D4FF;">医学生穿越者</div>
      <p class="card-desc">穿越三年，外表病弱美人，内心狠辣果断。随身带着七步散。</p>
      <div class="card-flowers">
        <span class="card-flower"><svg viewBox="0 0 24 24"><circle class="petal" cx="12" cy="7" r="4"/><circle class="petal" cx="7" cy="12" r="4"/><circle class="petal" cx="17" cy="12" r="4"/><circle class="petal" cx="9" cy="17" r="4"/><circle class="petal" cx="15" cy="17" r="4"/><circle cx="12" cy="12" r="3" fill="#FFD700"/></svg></span>
        <span class="card-flower"><svg viewBox="0 0 24 24"><circle class="petal" cx="12" cy="7" r="4"/><circle class="petal" cx="7" cy="12" r="4"/><circle class="petal" cx="17" cy="12" r="4"/><circle class="petal" cx="9" cy="17" r="4"/><circle class="petal" cx="15" cy="17" r="4"/><circle cx="12" cy="12" r="3" fill="#FFD700"/></svg></span>
        <span class="card-flower"><svg viewBox="0 0 24 24"><circle class="petal" cx="12" cy="7" r="4"/><circle class="petal" cx="7" cy="12" r="4"/><circle class="petal" cx="17" cy="12" r="4"/><circle class="petal" cx="9" cy="17" r="4"/><circle class="petal" cx="15" cy="17" r="4"/><circle cx="12" cy="12" r="3" fill="#FFD700"/></svg></span>
        <span class="card-flower"><svg viewBox="0 0 24 24"><circle class="petal" cx="12" cy="7" r="4"/><circle class="petal" cx="7" cy="12" r="4"/><circle class="petal" cx="17" cy="12" r="4"/><circle class="petal" cx="9" cy="17" r="4"/><circle class="petal" cx="15" cy="17" r="4"/><circle cx="12" cy="12" r="3" fill="#FFD700"/></svg></span>
        <span class="card-flower"><svg viewBox="0 0 24 24"><circle class="petal-empty" cx="12" cy="7" r="4"/><circle class="petal-empty" cx="7" cy="12" r="4"/><circle class="petal-empty" cx="17" cy="12" r="4"/><circle class="petal-empty" cx="9" cy="17" r="4"/><circle class="petal-empty" cx="15" cy="17" r="4"/><circle cx="12" cy="12" r="3" fill="rgba(255,68,68,0.15)"/></svg></span>
      </div>
      <div class="card-quote">
        <div class="quote-bubble">"三姐姐这辣条...啊不，这药，多少钱一包？"</div>
      </div>
    </div>

    <!-- Card 3: Xiao Zhu -->
    <div class="char-card" style="--card-accent: #7E4FC9;" data-delay="160">
      <div class="card-avatar" style="background: linear-gradient(135deg, rgba(168,85,247,0.2), rgba(120,50,200,0.1));">
        <span class="card-avatar-letter">竹</span>
      </div>
      <div class="card-name">小竹 (原夜枭)</div>
      <div class="card-title" style="color: #7E4FC9;">前刺客统领·现广播体操领操员</div>
      <p class="card-desc">22岁，沉默寡言，金穗刀换成了小红花。叫婉儿"姐"。</p>
      <div class="card-flowers">
        <span class="card-flower"><svg viewBox="0 0 24 24"><circle class="petal" cx="12" cy="7" r="4"/><circle class="petal" cx="7" cy="12" r="4"/><circle class="petal" cx="17" cy="12" r="4"/><circle class="petal" cx="9" cy="17" r="4"/><circle class="petal" cx="15" cy="17" r="4"/><circle cx="12" cy="12" r="3" fill="#FFD700"/></svg></span>
        <span class="card-flower"><svg viewBox="0 0 24 24"><circle class="petal" cx="12" cy="7" r="4"/><circle class="petal" cx="7" cy="12" r="4"/><circle class="petal" cx="17" cy="12" r="4"/><circle class="petal" cx="9" cy="17" r="4"/><circle class="petal" cx="15" cy="17" r="4"/><circle cx="12" cy="12" r="3" fill="#FFD700"/></svg></span>
        <span class="card-flower"><svg viewBox="0 0 24 24"><circle class="petal" cx="12" cy="7" r="4"/><circle class="petal" cx="7" cy="12" r="4"/><circle class="petal" cx="17" cy="12" r="4"/><circle class="petal" cx="9" cy="17" r="4"/><circle class="petal" cx="15" cy="17" r="4"/><circle cx="12" cy="12" r="3" fill="#FFD700"/></svg></span>
        <span class="card-flower"><svg viewBox="0 0 24 24"><circle class="petal-empty" cx="12" cy="7" r="4"/><circle class="petal-empty" cx="7" cy="12" r="4"/><circle class="petal-empty" cx="17" cy="12" r="4"/><circle class="petal-empty" cx="9" cy="17" r="4"/><circle class="petal-empty" cx="15" cy="17" r="4"/><circle cx="12" cy="12" r="3" fill="rgba(255,68,68,0.15)"/></svg></span>
        <span class="card-flower"><svg viewBox="0 0 24 24"><circle class="petal-empty" cx="12" cy="7" r="4"/><circle class="petal-empty" cx="7" cy="12" r="4"/><circle class="petal-empty" cx="17" cy="12" r="4"/><circle class="petal-empty" cx="9" cy="17" r="4"/><circle class="petal-empty" cx="15" cy="17" r="4"/><circle cx="12" cy="12" r="3" fill="rgba(255,68,68,0.15)"/></svg></span>
      </div>
      <div class="card-quote">
        <div class="quote-bubble">"......（点头）"</div>
      </div>
    </div>

    <!-- Card 4: Xiao Man -->
    <div class="char-card" style="--card-accent: #FF6B9D;" data-delay="240">
      <div class="card-avatar" style="background: linear-gradient(135deg, rgba(255,107,157,0.2), rgba(200,80,120,0.1));">
        <span class="card-avatar-letter">满</span>
      </div>
      <div class="card-name">小满</div>
      <div class="card-title" style="color: #FF6B9D;">HR副部长见习生</div>
      <p class="card-desc">12岁，小竹的师妹。戴三层小红花，气场强大。</p>
      <div class="card-flowers">
        <span class="card-flower"><svg viewBox="0 0 24 24"><circle class="petal" cx="12" cy="7" r="4"/><circle class="petal" cx="7" cy="12" r="4"/><circle class="petal" cx="17" cy="12" r="4"/><circle class="petal" cx="9" cy="17" r="4"/><circle class="petal" cx="15" cy="17" r="4"/><circle cx="12" cy="12" r="3" fill="#FFD700"/></svg></span>
        <span class="card-flower"><svg viewBox="0 0 24 24"><circle class="petal" cx="12" cy="7" r="4"/><circle class="petal" cx="7" cy="12" r="4"/><circle class="petal" cx="17" cy="12" r="4"/><circle class="petal" cx="9" cy="17" r="4"/><circle class="petal" cx="15" cy="17" r="4"/><circle cx="12" cy="12" r="3" fill="#FFD700"/></svg></span>
        <span class="card-flower"><svg viewBox="0 0 24 24"><circle class="petal-empty" cx="12" cy="7" r="4"/><circle class="petal-empty" cx="7" cy="12" r="4"/><circle class="petal-empty" cx="17" cy="12" r="4"/><circle class="petal-empty" cx="9" cy="17" r="4"/><circle class="petal-empty" cx="15" cy="17" r="4"/><circle cx="12" cy="12" r="3" fill="rgba(255,68,68,0.15)"/></svg></span>
        <span class="card-flower"><svg viewBox="0 0 24 24"><circle class="petal-empty" cx="12" cy="7" r="4"/><circle class="petal-empty" cx="7" cy="12" r="4"/><circle class="petal-empty" cx="17" cy="12" r="4"/><circle class="petal-empty" cx="9" cy="17" r="4"/><circle class="petal-empty" cx="15" cy="17" r="4"/><circle cx="12" cy="12" r="3" fill="rgba(255,68,68,0.15)"/></svg></span>
        <span class="card-flower"><svg viewBox="0 0 24 24"><circle class="petal-empty" cx="12" cy="7" r="4"/><circle class="petal-empty" cx="7" cy="12" r="4"/><circle class="petal-empty" cx="17" cy="12" r="4"/><circle class="petal-empty" cx="9" cy="17" r="4"/><circle class="petal-empty" cx="15" cy="17" r="4"/><circle cx="12" cy="12" r="3" fill="rgba(255,68,68,0.15)"/></svg></span>
      </div>
      <div class="card-quote">
        <div class="quote-bubble">"姐，我觉得这个年终总结写得不够狠。"</div>
      </div>
    </div>

    <!-- Card 5: Crown Prince -->
    <div class="char-card" style="--card-accent: #F59E0B;" data-delay="320">
      <div class="card-avatar" style="background: linear-gradient(135deg, rgba(245,158,11,0.2), rgba(200,130,10,0.1));">
        <span class="card-avatar-letter">太</span>
      </div>
      <div class="card-name">太子</div>
      <div class="card-title" style="color: #F59E0B;">被救回的大皇兄</div>
      <p class="card-desc">刚被大皇子绑架救出，穿着大了三号的骑装恢复中。开始怀疑婉儿的真实身份。</p>
      <div class="card-flowers">
        <span class="card-flower"><svg viewBox="0 0 24 24"><circle class="petal" cx="12" cy="7" r="4"/><circle class="petal" cx="7" cy="12" r="4"/><circle class="petal" cx="17" cy="12" r="4"/><circle class="petal" cx="9" cy="17" r="4"/><circle class="petal" cx="15" cy="17" r="4"/><circle cx="12" cy="12" r="3" fill="#FFD700"/></svg></span>
        <span class="card-flower"><svg viewBox="0 0 24 24"><circle class="petal" cx="12" cy="7" r="4"/><circle class="petal" cx="7" cy="12" r="4"/><circle class="petal" cx="17" cy="12" r="4"/><circle class="petal" cx="9" cy="17" r="4"/><circle class="petal" cx="15" cy="17" r="4"/><circle cx="12" cy="12" r="3" fill="#FFD700"/></svg></span>
        <span class="card-flower"><svg viewBox="0 0 24 24"><circle class="petal" cx="12" cy="7" r="4"/><circle class="petal" cx="7" cy="12" r="4"/><circle class="petal" cx="17" cy="12" r="4"/><circle class="petal" cx="9" cy="17" r="4"/><circle class="petal" cx="15" cy="17" r="4"/><circle cx="12" cy="12" r="3" fill="#FFD700"/></svg></span>
        <span class="card-flower"><svg viewBox="0 0 24 24"><circle class="petal-empty" cx="12" cy="7" r="4"/><circle class="petal-empty" cx="7" cy="12" r="4"/><circle class="petal-empty" cx="17" cy="12" r="4"/><circle class="petal-empty" cx="9" cy="17" r="4"/><circle class="petal-empty" cx="15" cy="17" r="4"/><circle cx="12" cy="12" r="3" fill="rgba(255,68,68,0.15)"/></svg></span>
        <span class="card-flower"><svg viewBox="0 0 24 24"><circle class="petal-empty" cx="12" cy="7" r="4"/><circle class="petal-empty" cx="7" cy="12" r="4"/><circle class="petal-empty" cx="17" cy="12" r="4"/><circle class="petal-empty" cx="9" cy="17" r="4"/><circle class="petal-empty" cx="15" cy="17" r="4"/><circle cx="12" cy="12" r="3" fill="rgba(255,68,68,0.15)"/></svg></span>
      </div>
      <div class="card-quote">
        <div class="quote-bubble">"七妹...你到底是谁？"</div>
      </div>
    </div>
  </div>
</section>

<!-- ══════════════════ Animal Squad ══════════════════ -->
<div class="animal-section-bg">
<section class="section" id="animals" data-od-id="animals" data-component="animal-squad">
  <div class="section-header fade-up">
    <p class="section-sub">动物小队</p>
    <h2>精神海招聘部</h2>
    <div class="section-line" style="background: var(--seed-spiritual);"></div>
  </div>

  <div class="animal-grid">
    <!-- Cat: Dou Dou -->
    <div class="animal-card" style="--card-accent: #FF8C00;" data-delay="0">
      <div class="animal-icon-wrap" style="background: linear-gradient(135deg, rgba(255,140,0,0.2), rgba(200,100,0,0.1));">
        <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 16L8 4L20 12H44L56 4L52 16C54 20 56 26 56 32C56 44 46 56 32 58C18 56 8 44 8 32C8 26 10 20 12 16Z" fill="#FF8C00"/>
          <ellipse cx="24" cy="30" rx="3" ry="4" fill="#0A0A12"/>
          <ellipse cx="40" cy="30" rx="3" ry="4" fill="#0A0A12"/>
          <ellipse cx="32" cy="38" rx="3" ry="2" fill="#FFB6C1"/>
          <path d="M28 42Q32 46 36 42" stroke="#0A0A12" stroke-width="1.5" fill="none" stroke-linecap="round"/>
          <line x1="10" y1="30" x2="22" y2="32" stroke="#0A0A12" stroke-width="1" opacity="0.4"/>
          <line x1="10" y1="34" x2="22" y2="34" stroke="#0A0A12" stroke-width="1" opacity="0.4"/>
          <line x1="42" y1="32" x2="54" y2="30" stroke="#0A0A12" stroke-width="1" opacity="0.4"/>
          <line x1="42" y1="34" x2="54" y2="34" stroke="#0A0A12" stroke-width="1" opacity="0.4"/>
        </svg>
      </div>
      <div class="animal-info">
        <div class="animal-name">豆豆</div>
        <div class="animal-species">黄猫 · 屋顶情报员</div>
        <p class="animal-desc">毒舌担当，吐槽功力天下第一。名言涉及尿桶等不雅回忆。</p>
        <div class="animal-quote" style="border-color: #FF8C00;">"上次本喵掉进尿桶的时候..."</div>
      </div>
    </div>

    <!-- Crow: A Hei -->
    <div class="animal-card" style="--card-accent: #4A4A5A;" data-delay="100">
      <div class="animal-icon-wrap" style="background: linear-gradient(135deg, rgba(74,74,90,0.3), rgba(50,50,60,0.15));">
        <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M8 28C8 28 4 22 10 18C16 14 22 18 22 18L28 14C28 14 24 8 30 6C36 4 38 10 38 10L42 14C42 14 48 12 52 16C56 20 52 26 52 26L48 30C48 30 54 34 52 40C50 46 44 44 44 44L38 40L32 44L26 40L20 44C20 44 14 46 12 40C10 34 16 30 16 30L8 28Z" fill="#4A4A5A"/>
          <circle cx="26" cy="24" r="3" fill="#F5F0E8"/>
          <circle cx="26" cy="24" r="1.5" fill="#0A0A12"/>
          <path d="M36 26L42 24L36 28Z" fill="#FFD700"/>
          <path d="M18 48L22 44L20 52Z" fill="#4A4A5A"/>
          <path d="M44 48L40 44L42 52Z" fill="#4A4A5A"/>
        </svg>
      </div>
      <div class="animal-info">
        <div class="animal-name">阿黑</div>
        <div class="animal-species">乌鸦 · 空中侦察兵</div>
        <p class="animal-desc">负责空中侦察和传信，沉默高效。</p>
        <div class="animal-quote" style="border-color: #4A4A5A;">"......（振翅）"</div>
      </div>
    </div>

    <!-- Fish: Pang Ju -->
    <div class="animal-card" style="--card-accent: #FF6347;" data-delay="200">
      <div class="animal-icon-wrap" style="background: linear-gradient(135deg, rgba(255,99,71,0.2), rgba(200,60,40,0.1));">
        <svg viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg">
          <ellipse cx="30" cy="32" rx="20" ry="14" fill="#FF6347"/>
          <path d="M48 32C48 32 58 22 58 32C58 42 48 32 48 32Z" fill="#FF6347"/>
          <path d="M48 32C48 32 58 22 58 32C58 42 48 32 48 32Z" fill="rgba(0,0,0,0.15)"/>
          <ellipse cx="20" cy="28" rx="2.5" ry="3" fill="#0A0A12"/>
          <ellipse cx="20" cy="28" rx="1" ry="1.5" fill="#F5F0E8"/>
          <path d="M28 20Q34 16 40 20" stroke="rgba(0,0,0,0.2)" stroke-width="1.5" fill="none"/>
          <path d="M28 44Q34 48 40 44" stroke="rgba(0,0,0,0.2)" stroke-width="1.5" fill="none"/>
          <path d="M14 36Q18 38 22 36" stroke="rgba(0,0,0,0.15)" stroke-width="1" fill="none"/>
          <circle cx="30" cy="38" r="4" fill="rgba(255,200,150,0.3)"/>
        </svg>
      </div>
      <div class="animal-info">
        <div class="animal-name">胖橘</div>
        <div class="animal-species">锦鲤 · 池塘摸鱼王</div>
        <p class="animal-desc">池塘里的搞笑担当，存在感全靠蹦跶。</p>
        <div class="animal-quote" style="border-color: #FF6347;">"（蹦出水面甩了一脸水花）"</div>
      </div>
    </div>

    <!-- Dog: Lang Gou Ge -->
    <div class="animal-card" style="--card-accent: #8B6914;" data-delay="300">
