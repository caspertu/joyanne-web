---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getPublishedChapters, formatChapterLabel } from '../lib/chapters';
import site from '../../content-meta/site.json';

const chapters = await getPublishedChapters();
const latest = chapters[chapters.length - 1];
const totalWords = chapters.reduce((sum, c) => sum + c.data.wordCount, 0);
---

<BaseLayout title={site.title} description={site.hook}>
  <div class="mx-auto max-w-2xl px-4 py-12 md:py-20">
    <header class="mb-12 text-center">
      <p class="mb-3 text-sm tracking-[0.3em] text-accent">第一卷</p>
      <h1 class="mb-4 font-serif text-3xl font-bold leading-tight md:text-4xl">{site.title}</h1>
      <p class="text-lg text-ink/70">{site.hook}</p>
    </header>

    <div class="mb-10 rounded-2xl border border-accent-light bg-white/50 p-6 shadow-sm">
      <p class="mb-1 text-sm text-ink/50">连载进度</p>
      <p class="font-serif text-xl">
        已更新 <span class="font-bold text-accent">{chapters.length}</span> 章 · 共{' '}
        <span class="font-bold text-accent">{totalWords.toLocaleString()}</span> 字
      </p>
      {
        latest && (
          <p class="mt-3 text-sm text-ink/60">
            最新：{formatChapterLabel(latest)}
          </p>
        )
      }
    </div>

    <div class="flex flex-col gap-3 sm:flex-row sm:justify-center">
      <a
        href="/read/chapter-01"
        class="inline-flex min-h-12 items-center justify-center rounded-xl bg-accent px-8 text-lg font-medium text-white shadow-md hover:bg-accent/90"
      >
        从第一章开始读
      </a>
      <a
        href="/read"
        class="inline-flex min-h-12 items-center justify-center rounded-xl border border-accent/30 px-8 text-lg text-accent hover:bg-accent/5"
      >
        章节目录
      </a>
    </div>

    <p class="mt-16 text-center text-sm text-ink/40">写给 Joyanne 的故事 · 幽默优先</p>
  </div>
</BaseLayout>